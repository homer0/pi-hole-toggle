{
  "name": "pi-hole-toggle",
  "description": "Just a toggle to turn on and off Pi-hole blocking",
  "version": "1.0.0",
  "repository": "homer0/pi-hole-toggle",
  "author": "Leonardo Apiwan (@homer0) <me@homer0.com>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "test": "echo \"lol\"",
    "dev": "bun run --watch src/index.tsx",
    "start": "bun run src/index.tsx",
    "lint": "lint-staged",
    "lint:all": "eslint ./ --ext .js --ext .jsx --ext .ts --ext .tsx",
    "types:check": "tsc --noEmit",
    "prepare": "husky || true",
    "docker:build": "docker build -t pi-hole-toggle ."
  },
  "dependencies": {
    "@elysiajs/html": "^1.4.2",
    "@elysiajs/static": "^1.4.10",
    "elysia": "^1.4.29"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@homer0/eslint-plugin": "^14.2.4",
    "@homer0/prettier-config": "^2.0.1",
    "@homer0/tsconfig": "^5.0.0",
    "@types/node": "^24.13.3",
    "eslint": "^9.39.5",
    "typescript": "^6.0.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "bun-types": "^1.3.14"
  },
  "engine-strict": true,
  "engines": {
    "node": "24.x",
    "pnpm": ">=7"
  },
  "module": "src/index.js",
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,css,scss,md}": [
      "./utils/lint-staged-prettier.sh"
    ],
    "*.{ts,tsx,js}": [
      "eslint"
    ]
  },
  "trustedDependencies": [
    "unrs-resolver"
  ]
}
